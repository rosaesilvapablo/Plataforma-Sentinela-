rules_version = '2';

// =====================================================================
// Plataforma Sentinela 2026 — Regras Firestore
//
// LICOES APRENDIDAS do legado:
//   - Firestore avalia TODOS os matches e libera se QUALQUER um permitir
//     (logica OR). NUNCA escreva uma regra generica /{collection}/{docId}
//     que duplique colecoes ja cobertas por blocos especificos — amplia
//     o acesso e anula validacoes.
//   - Prefira deny-all + bloco explicito por colecao.
//   - admin e diretor sao funcionalmente identicos (CRUD total) — use
//     `hasFullAccess()` como helper.
//
// Cada modulo adiciona seu proprio bloco abaixo, conforme entregue.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasFullAccess() {
      return isAuthenticated()
        && (request.auth.token.role == 'admin' || request.auth.token.role == 'diretor');
    }

    // ===== Regra mestra: admin/diretor tem CRUD total =====
    match /{document=**} {
      allow read, write: if hasFullAccess();
    }

    // ===== Modulo Admin → Usuarios =====
    //
    // access_list e lida por admin/diretor (cobertos pela regra mestra acima).
    // Escrita acontece SOMENTE via Cloud Functions (admin SDK ignora rules),
    // o que garante atomicidade com auth.setCustomUserClaims e auditabilidade.
    // Cliente nao pode escrever direto.
    match /access_list/{uid} {
      allow read: if hasFullAccess();
      allow write: if false;
    }

    // ===== Deny-all default =====
    // Qualquer coisa nao coberta acima e negada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
