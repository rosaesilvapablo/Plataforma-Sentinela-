rules_version = '2';

// =====================================================================
// Plataforma Sentinela 2026 — Regras Firestore
//
// PRINCIPIOS (do `docs/ARQUITETURA.md`):
//   1. Deny-all por padrao + bloco EXPLICITO por colecao.
//   2. NUNCA usar regra mestra wildcard `match /{document=**}` para
//      conceder acesso — ela ANULA validacoes por colecao (logica OR
//      do Firestore amplia o acesso). Foi exatamente o bug critico do
//      legado.
//   3. admin e diretor sao funcionalmente identicos (CRUD total) via
//      helper `hasFullAccess()` — mas precisam estar listados em CADA
//      bloco de colecao, nao via wildcard.
//   4. Validacao de schema (`hasOnly` + tipos + enums) em CADA escrita.
//
// Cada novo modulo adiciona seu proprio bloco abaixo, com validacao.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasFullAccess() {
      return isAuthenticated()
        && (request.auth.token.role == 'admin' || request.auth.token.role == 'diretor');
    }

    // ===== Modulo Admin → Usuarios =====
    // access_list e gerenciada via Cloud Functions (admin SDK).
    // Cliente le; nao escreve.
    match /access_list/{uid} {
      allow read: if hasFullAccess();
      allow write: if false;
    }

    // ===== Modulo Equipe → Cadastro =====

    function teamAllowedKeys() {
      return ['nome', 'email', 'matricula', 'cargoEfetivo', 'funcaoComissionada',
              'tipoVinculo', 'lotacaoParadigma', 'lotacaoAtual', 'status',
              'observacoes', 'createdAt', 'updatedAt'];
    }

    function teamRequiredKeys() {
      return ['nome', 'email', 'matricula', 'cargoEfetivo',
              'tipoVinculo', 'lotacaoParadigma', 'lotacaoAtual', 'status'];
    }

    function teamValidTipoVinculo() {
      return request.resource.data.tipoVinculo in
        ['juiz', 'servidor', 'estagiario', 'terceirizado',
         'cedido', 'requisitado', 'voluntario'];
    }

    function teamValidStatus() {
      return request.resource.data.status in ['ativo', 'afastado', 'desligado'];
    }

    function teamValidShape() {
      return request.resource.data.keys().hasOnly(teamAllowedKeys())
        && request.resource.data.keys().hasAll(teamRequiredKeys())
        && request.resource.data.nome is string
        && request.resource.data.email is string
        && request.resource.data.matricula is string
        && request.resource.data.cargoEfetivo is string
        && request.resource.data.lotacaoParadigma is string
        && request.resource.data.lotacaoAtual is string
        && teamValidTipoVinculo()
        && teamValidStatus();
    }

    function teamCargoEfetivoUnchanged() {
      // Em update, cargoEfetivo nao pode mudar (regra de negocio).
      return resource.data.cargoEfetivo == request.resource.data.cargoEfetivo;
    }

    match /team/{memberId} {
      // Leitura: todos os autenticados (consulta de equipe e operacional).
      allow read: if isAuthenticated();
      // Escrita: admin/diretor com schema valido.
      allow create: if hasFullAccess() && teamValidShape();
      allow update: if hasFullAccess() && teamValidShape() && teamCargoEfetivoUnchanged();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Equipe → Frequencia =====
    //
    // docId AUTOGERADO pelo Firestore (corrige bug do legado em que userId
    // era usado como docId e sobrescrevia historico).
    // Nesta v1: leitura e escrita apenas admin/diretor. Self-service do
    // proprio servidor (ler/criar pedidos pendentes) e follow-up — exige
    // ligar team.authUid ao auth UID.

    function frequenciaAllowedKeys() {
      return ['memberId', 'memberNome', 'tipo', 'dataInicio', 'dataFim',
              'motivo', 'observacoes', 'createdByUid', 'createdByName',
              'createdAt', 'updatedAt'];
    }

    function frequenciaRequiredKeys() {
      return ['memberId', 'memberNome', 'tipo', 'dataInicio', 'dataFim',
              'createdByUid', 'createdByName'];
    }

    function frequenciaValidTipo() {
      return request.resource.data.tipo in
        ['ausencia_justificada', 'falta_injustificada'];
    }

    function frequenciaValidShape() {
      return request.resource.data.keys().hasOnly(frequenciaAllowedKeys())
        && request.resource.data.keys().hasAll(frequenciaRequiredKeys())
        && request.resource.data.memberId is string
        && request.resource.data.memberNome is string
        && request.resource.data.createdByUid is string
        && request.resource.data.createdByName is string
        && request.resource.data.dataInicio is timestamp
        && request.resource.data.dataFim is timestamp
        && request.resource.data.dataInicio <= request.resource.data.dataFim
        && frequenciaValidTipo();
    }

    function frequenciaMemberIdUnchanged() {
      return resource.data.memberId == request.resource.data.memberId;
    }

    match /frequencias/{id} {
      allow read: if hasFullAccess();
      allow create: if hasFullAccess() && frequenciaValidShape();
      allow update: if hasFullAccess() && frequenciaValidShape() && frequenciaMemberIdUnchanged();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Equipe → Plantao =====

    function plantaoValidShape() {
      return request.resource.data.keys().hasOnly([
        'juizId', 'juizNome', 'servidorId', 'servidorNome', 'tipo',
        'dataInicio', 'dataFim', 'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll([
          'juizId', 'juizNome', 'servidorId', 'servidorNome', 'tipo',
          'dataInicio', 'dataFim'
        ])
        && request.resource.data.juizId is string
        && request.resource.data.servidorId is string
        && request.resource.data.dataInicio is timestamp
        && request.resource.data.dataFim is timestamp
        && request.resource.data.dataInicio <= request.resource.data.dataFim
        && request.resource.data.tipo in ['ordinario', 'extraordinario', 'recesso'];
    }

    match /plantoes/{id} {
      allow read: if isAuthenticated();
      allow create: if hasFullAccess() && plantaoValidShape();
      allow update: if hasFullAccess() && plantaoValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Equipe → Regime de Trabalho =====

    function regimeValidShape() {
      return request.resource.data.keys().hasOnly([
        'memberId', 'memberNome', 'tipo', 'processoSei',
        'dataInicio', 'dataFimPrevista', 'observacoes',
        'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll([
          'memberId', 'memberNome', 'tipo', 'processoSei', 'dataInicio'
        ])
        && request.resource.data.memberId is string
        && request.resource.data.processoSei is string
        && request.resource.data.dataInicio is timestamp
        && request.resource.data.tipo in ['presencial', 'hibrido', 'integral_remoto'];
    }

    match /regime_trabalho/{id} {
      allow read: if hasFullAccess();
      allow create: if hasFullAccess() && regimeValidShape();
      allow update: if hasFullAccess() && regimeValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo PPL Criminal =====

    function pplCanRead() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'juiz', 'supervisor', 'servidor'];
    }

    function pplValidShape() {
      return request.resource.data.keys().hasOnly([
        'nome', 'cpf', 'rg', 'processo', 'tipoPrisao', 'dataPrisao',
        'ultimaRevisao', 'proximaRevisao', 'unidade', 'observacoes',
        'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll(['nome', 'processo', 'tipoPrisao', 'dataPrisao'])
        && request.resource.data.nome is string
        && request.resource.data.processo is string
        && request.resource.data.dataPrisao is timestamp
        && request.resource.data.tipoPrisao in
          ['preventiva', 'temporaria', 'flagrante', 'definitiva',
           'monitoramento_eletronico', 'outra'];
    }

    match /ppl/{id} {
      allow read: if pplCanRead();
      allow create: if hasFullAccess() && pplValidShape();
      allow update: if hasFullAccess() && pplValidShape();
      allow delete: if hasFullAccess();
    }

    function mandadoValidShape() {
      return request.resource.data.keys().hasOnly([
        'pessoa', 'processo', 'categoria', 'prazo', 'status',
        'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll(['pessoa', 'processo', 'categoria', 'status'])
        && request.resource.data.pessoa is string
        && request.resource.data.processo is string
        && request.resource.data.categoria in
          ['pendente_cumprimento', 'difusao_vermelha', 'revisao_316']
        && request.resource.data.status in ['ativo', 'cumprido', 'cancelado'];
    }

    match /mandados/{id} {
      allow read: if pplCanRead();
      allow create: if hasFullAccess() && mandadoValidShape();
      allow update: if hasFullAccess() && mandadoValidShape();
      allow delete: if hasFullAccess();
    }

    // Testemunhas: acesso ainda mais restrito (diretor/juiz/admin), Lei 9.807/99.
    function testemunhaCanRead() {
      return isAuthenticated() && request.auth.token.role in ['admin', 'diretor', 'juiz'];
    }

    function testemunhaValidShape() {
      return request.resource.data.keys().hasOnly([
        'codigo', 'caso', 'status', 'dataInclusao', 'dataEncerramento',
        'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll(['codigo', 'caso', 'status', 'dataInclusao'])
        && request.resource.data.codigo is string
        && request.resource.data.caso is string
        && request.resource.data.dataInclusao is timestamp
        && request.resource.data.status in ['ativo', 'encerrado'];
    }

    match /protected_witnesses/{id} {
      allow read: if testemunhaCanRead();
      allow create: if hasFullAccess() && testemunhaValidShape();
      allow update: if hasFullAccess() && testemunhaValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Expedientes =====

    function expedienteCanRead() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'juiz', 'supervisor', 'servidor'];
    }

    function expedienteCanWrite() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'supervisor', 'servidor'];
    }

    function expedienteValidShape() {
      return request.resource.data.keys().hasOnly([
        'processo', 'tipo', 'destinatario', 'assunto', 'status',
        'dataEmissao', 'prazoDevolucao', 'dataCumprimento',
        'responsavel', 'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll([
          'processo', 'tipo', 'destinatario', 'assunto', 'status'
        ])
        && request.resource.data.processo is string
        && request.resource.data.destinatario is string
        && request.resource.data.assunto is string
        && request.resource.data.tipo in
          ['oficio', 'carta_precatoria', 'mandado_diligencia']
        && request.resource.data.status in
          ['pendente', 'emitido', 'em_diligencia', 'cumprido', 'cancelado'];
    }

    match /expedientes/{id} {
      allow read: if expedienteCanRead();
      allow create: if expedienteCanWrite() && expedienteValidShape();
      allow update: if expedienteCanWrite() && expedienteValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Mesa de Trabalho (Kanban) =====

    function mesaCanWrite() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'supervisor', 'servidor'];
    }

    function mesaValidShape() {
      return request.resource.data.keys().hasOnly([
        'titulo', 'processo', 'column', 'assigneeId', 'assigneeNome',
        'prazo', 'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll(['titulo', 'processo', 'column'])
        && request.resource.data.titulo is string
        && request.resource.data.processo is string
        && request.resource.data.column in
          ['concluso_despacho', 'concluso_decisao', 'concluso_sentenca',
           'em_diligencia', 'concluido'];
    }

    match /mesa_cards/{id} {
      allow read: if expedienteCanRead();
      allow create: if mesaCanWrite() && mesaValidShape();
      allow update: if mesaCanWrite() && mesaValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo SISBAJUD & Depositos =====

    function sisbajudCanRead() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'juiz', 'supervisor', 'servidor'];
    }

    function sisbajudOrdemValidShape() {
      return request.resource.data.keys().hasOnly([
        'processo', 'ordem', 'pessoa', 'valor', 'status', 'data',
        'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll([
          'processo', 'ordem', 'pessoa', 'valor', 'status', 'data'
        ])
        && request.resource.data.valor is number
        && request.resource.data.valor >= 0
        && request.resource.data.data is timestamp
        && request.resource.data.status in
          ['pendente', 'bloqueado', 'transferido', 'cancelado'];
    }

    match /sisbajud_ordens/{id} {
      allow read: if sisbajudCanRead();
      allow create: if hasFullAccess() && sisbajudOrdemValidShape();
      allow update: if hasFullAccess() && sisbajudOrdemValidShape();
      allow delete: if hasFullAccess();
    }

    function depositoValidShape() {
      return request.resource.data.keys().hasOnly([
        'processo', 'conta', 'valor', 'data', 'ordemSisbajudId',
        'observacoes', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll(['processo', 'conta', 'valor', 'data'])
        && request.resource.data.valor is number
        && request.resource.data.valor >= 0
        && request.resource.data.data is timestamp
        && request.resource.data.conta in ['anpp', 'prd', 'conta_unica', 'judicial'];
    }

    match /depositos_sisbajud/{id} {
      allow read: if sisbajudCanRead();
      allow create: if hasFullAccess() && depositoValidShape();
      allow update: if hasFullAccess() && depositoValidShape();
      allow delete: if hasFullAccess();
    }

    // ===== Modulo Recolhimentos & Gestao =====

    // Orientacoes: doc unico, todos autenticados leem, apenas admin/diretor edita
    match /recolhimentos_orientacoes/main {
      allow read: if isAuthenticated();
      allow write: if hasFullAccess()
        && request.resource.data.keys().hasOnly([
          'conteudo', 'updatedAt', 'updatedByUid', 'updatedByName'
        ])
        && request.resource.data.conteudo is string;
    }

    function movimentoValidShape() {
      return request.resource.data.keys().hasOnly([
        'conta', 'tipo', 'valor', 'data', 'descricao', 'destinacao',
        'processo', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.keys().hasAll([
          'conta', 'tipo', 'valor', 'data', 'descricao'
        ])
        && request.resource.data.valor is number
        && request.resource.data.valor >= 0
        && request.resource.data.data is timestamp
        && request.resource.data.conta in ['anpp', 'prd', 'conta_unica']
        && request.resource.data.tipo in ['entrada', 'saida'];
    }

    match /contas_movimentos/{id} {
      allow read: if hasAccessJuizadoFinanceiro();
      allow create: if hasFullAccess() && movimentoValidShape();
      allow update: if hasFullAccess() && movimentoValidShape();
      allow delete: if hasFullAccess();
    }

    function hasAccessJuizadoFinanceiro() {
      return isAuthenticated() && request.auth.token.role in
        ['admin', 'diretor', 'juiz'];
    }

    // ===== Deny-all default =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
