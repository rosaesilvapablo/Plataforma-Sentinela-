# Configuracao Firebase Web (publica — copiada do console do Firebase).
# Copie este arquivo para .env.local e preencha com os valores do SEU novo
# projeto Firebase. NUNCA comite .env nem .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA Enterprise / v3 site key — habilitar em producao)
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Identificador organizacional principal usado nas colecoes Firestore.
# Mantido fora do codigo para permitir multi-tenant no futuro.
VITE_ORG_ID=vara_federal_4
